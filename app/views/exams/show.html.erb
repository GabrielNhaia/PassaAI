<div class="container-fluid">
  <div class="row">
    <%= render 'shared/sidebar' %>
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
      <% if @exam.redacao? %>
        <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
          <h1 class="h2">Detalhes da Redação</h1>
          <%= link_to profile_path, class: "btn btn-outline-secondary" do %>
            <i class="bi bi-arrow-left"></i> Voltar
          <% end %>
        </div>
        <div class="card mb-4">
          <div class="card-header">
            <h3>Nota Final: <%= @exam.essay_total_score %></h3>
          </div>
          <div class="card-body">
            <h4>Feedback Geral</h4>
            <p><%= @exam.essay_general_feedback %></p>
            <h4 class="mt-4">Notas por Competência</h4>
            <div class="accordion" id="competenciasAccordion">
              <% (1..5).each do |i| %>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#comp<%= i %>">
                      Competência <%= i %> - Nota: <%= @exam.send("comp#{i}_score") %>
                    </button>
                  </h2>
                  <div id="comp<%= i %>" class="accordion-collapse collapse">
                    <div class="accordion-body">
                      <%= @exam.send("comp#{i}_feedback") %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        <div class="card">
          <div class="card-header">
            <h4>Sua Redação</h4>
          </div>
          <div class="card-body">
            <h5>Tema: <%= @exam.selected_theme %></h5>
            <p class="mt-3"><%= simple_format(@exam.essay_text) %></p>
          </div>
        </div>
      <% else %>
        <div class="col-12">
          <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Detalhes do Simulado</h2>
            <%= link_to profile_path, class: "btn btn-outline-secondary" do %>
              <i class="bi bi-arrow-left"></i> Voltar
            <% end %>
          </div>
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">Desempenho</h5>
              <p class="card-text">Total de Questões: <%= @exam_statistics[:total_questions] %></p>
              <p class="card-text">Respostas Corretas: <%= @exam_statistics[:correct_answers] %></p>
              <p class="card-text">Pontuação: <%= @exam_statistics[:score] %>%</p>
              <% if @exam_statistics[:duration].present? %>
                <p class="card-text">Duração: <%= @exam_statistics[:duration] %></p>
              <% end %>
            </div>
          </div>
          <div class="mt-4">
            <h5>Detalhamento das Questões</h5>
            <div class="accordion" id="questionsAccordion">
              <% @exam.exam_questions.each_with_index do |exam_question, index| %>
                <div class="accordion-item">
                  <h2 class="accordion-header">
                    <button class="accordion-button <%= 'collapsed' unless index == 0 %> d-flex align-items-center" type="button" data-bs-toggle="collapse" data-bs-target="#question<%= index %>" style="gap: 10px;">
                      <span style="flex: 1;">
                        <strong>Questão <%= index + 1 %>:</strong> <%= exam_question.question.content.truncate(100) %>
                      </span>
                      <% if exam_question.correct %>
                        <span class="badge bg-success" style="flex-shrink: 0;">Correta</span>
                      <% else %>
                        <span class="badge bg-danger" style="flex-shrink: 0;">Incorreta</span>
                      <% end %>
                    </button>
                  </h2>
                  <div id="question<%= index %>" class="accordion-collapse collapse <%= 'show' if index == 0 %>">
                    <div class="accordion-body">
                      <p><strong>Questão:</strong> <%= exam_question.question.content %></p>
                      <ul class="list-unstyled">
                        <li><strong>a)</strong> <%= exam_question.question.answer_a %></li>
                        <li><strong>b)</strong> <%= exam_question.question.answer_b %></li>
                        <li><strong>c)</strong> <%= exam_question.question.answer_c %></li>
                        <li><strong>d)</strong> <%= exam_question.question.answer_d %></li>
                        <li><strong>e)</strong> <%= exam_question.question.answer_e %></li>
                      </ul>
                      <p><strong>Sua Resposta:</strong> <span class="<%= exam_question.correct ? 'text-success' : 'text-danger' %>"><%= exam_question.selected_answer %></span></p>
                      <p><strong>Resposta Correta:</strong> <span class="text-success"><%= exam_question.question.correct_answer %></span></p>
                      <% if exam_question.question.explanation.present? %>
                        <div class="alert alert-info mt-3">
                          <strong>Explicação:</strong> <%= exam_question.question.explanation %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </main>
  </div>
</div>
