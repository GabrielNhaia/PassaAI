<div class="container-fluid">
  <div class="row">
    <%= render 'shared/sidebar' %>
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <div class="d-flex align-items-center">
          <%= link_to dashboard_path, class: "btn btn-outline-secondary me-3" do %>
            <i class="bi bi-arrow-left"></i> Voltar
          <% end %>
          <h1 class="h2">Meu Perfil</h1>
        </div>
      </div>
      <div class="row mb-4">
        <div class="col-md-12">
          <div class="card">
            <div class="card-body">
              <div class="row">
                <div class="col-md-3 text-center">
                  <% if current_user.avatar.attached? %>
                    <%= image_tag current_user.avatar_thumbnail, class: "rounded-circle img-thumbnail", style: "width: 150px; height: 150px; object-fit: cover;" %>
                  <% else %>
                    <i class="bi bi-person-circle" style="font-size: 5rem;"></i>
                  <% end %>
                </div>
                <div class="col-md-9">
                  <h3 class="mb-3"><%= current_user.nickname %></h3>
                  <h5 class="text-muted mb-3"><%= current_user.email %></h5>
                  <p class="text-muted mb-2">Membro desde: <%= current_user.created_at.strftime("%d/%m/%Y") %></p>
                  <p class="text-muted">Total de simulados realizados: <%= @total_simulados %></p>
                  <%= link_to "Editar Conta", edit_user_registration_path, class: "btn btn-outline-primary mt-3" if current_page?(profile_path) %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="row mb-4">
        <div class="col-md-6">
          <div class="card">
            <div class="card-header">
              <h5 class="card-title mb-0">Médias por Matéria</h5>
            </div>
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-hover">
                  <thead>
                    <tr>
                      <th>Matéria</th>
                      <th>Média</th>
                      <th>Progresso</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if @media_por_materia&.any? %>
                      <% @media_por_materia.each do |materia| %>
                        <tr>
                          <td><%= materia[:materia] %></td>
                          <td><%= materia[:media] %>%</td>
                          <td>
                            <div class="progress">
                              <div class="progress-bar bg-success" role="progressbar" style="width: <%= materia[:media] %>%"></div>
                            </div>
                          </td>
                        </tr>
                      <% end %>
                    <% else %>
                      <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                          <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                          Nenhum dado disponível. Complete alguns simulados para ver suas médias por matéria.
                        </td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card">
            <div class="card-header">
              <h5 class="card-title mb-0">Evolução das Notas</h5>
            </div>
            <div class="card-body">
              <canvas id="evolutionChart" width="400" height="250"></canvas>
            </div>
          </div>
        </div>
      </div>
      <div class="card mb-4">
        <div class="card-header">
          <h5 class="card-title mb-0">Histórico de Simulados</h5>
        </div>
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Data</th>
                  <th>Simulado</th>
                  <th>Matéria</th>
                  <th>Nota</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                <% if @historico_simulados&.any? %>
                  <% @historico_simulados.each do |exam| %>
                    <tr>
                      <td><%= exam[:completed_at]&.strftime("%d/%m/%Y") || 'N/A' %></td>
                      <td>Simulado #<%= exam[:id] %></td>
                      <td><%= exam[:category] %></td>
                      <td><%= exam[:score] %>%</td>
                      <td>
                        <%= link_to "Ver Detalhes", 
                            exam_path(exam[:id]), 
                          class: "btn btn-sm btn-outline-primary" %>
                    </td>
                  </tr>
                  <% end %>
                <% else %>
                  <tr>
                    <td colspan="5" class="text-center text-muted py-4">
                      <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                      Nenhum simulado realizado ainda.
                      <%= link_to "Fazer Primeiro Simulado", simulados_path, class: "btn btn-primary btn-sm mt-2" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <% @study_goals.each do |goal_type, goal| %>
        <div class="goal-progress">
          <div class="progress-bar">
            <div class="progress-fill" style="width: <%= goal[:percentage] %>%"></div>
          </div>
          <span><%= goal[:current] %>/<%= goal[:target] %></span>
        </div>
      <% end %>
    </main>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener('turbo:load', function() {
    const ctx = document.getElementById('evolutionChart');
    if (!ctx) return;
    
    const evolucaoData = <%= raw (@evolucao_notas || []).to_json %>;

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: evolucaoData.map(d => d.mes),
        datasets: [{
          label: 'Média Geral',
          data: evolucaoData.map(d => d.media),
          borderColor: '#4A90E2',
          tension: 0.1
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false
      }
    });
  });
</script>
